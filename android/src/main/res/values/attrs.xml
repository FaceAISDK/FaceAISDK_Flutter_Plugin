<resources>

    <!-- 1:1 人脸识别覆盖视图，动作活体进度条，炫彩活体闪光颜色 -->
    <declare-styleable name="FaceVerifyCoverView">

        <!--文本-->
        <attr name="main_tip_text" format="string" />
        <!--提示文本颜色-->
        <attr name="tip_text_color" format="color" />
        <!--提示背景颜色-->
        <attr name="tip_text_bg_color" format="color" />
        <!--提示文字大小-->
        <attr name="tip_text_size" format="dimension" />

        <!--炫彩颜色，改变背景色-->
        <attr name="flash_color" format="color" />
        <attr name="background_color" format="color" />
        <attr name="progress_start_color" format="color" />
        <attr name="progress_end_color" format="color" />
        <attr name="show_progress" format="boolean" />

    </declare-styleable>



</resources>
